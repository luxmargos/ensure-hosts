{
  "name": "@luxmargos/ensure-hosts",
  "version": "0.1.0",
  "description": "CLI for managing hosts file entries from YAML profiles.",
  "type": "module",
  "bin": {
    "ensure-hosts": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "demo": "node dist/cli.js --config fixtures/simple.yaml",
    "demo-remove": "node dist/cli.js --config fixtures/simple.yaml --remove",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
